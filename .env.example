# ==============================================================================
# MTG RAG Pipeline — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Neon Postgres (free tier) ---
# Get yours at https://neon.tech → Create Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/mtg_rag?sslmode=require

# --- Embedding backend ---
# Options: "huggingface" (default, free/local) or "openai" (API, requires key)
EMBEDDING_BACKEND=huggingface

# HuggingFace model (used when EMBEDDING_BACKEND=huggingface)
# Default: sentence-transformers/all-MiniLM-L6-v2 (384 dims, fast, good quality)
# Other options: sentence-transformers/all-mpnet-base-v2 (768 dims, higher quality)
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenAI settings (used when EMBEDDING_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Optional overrides ---
# MTGJSON_BASE_URL=https://mtgjson.com/api/v5
# MTG_RULES_URL=https://media.wizards.com/2026/downloads/MagicCompRules%2020260227.txt
